---
import type { TournamentCard } from '../lib/queries';
import { SURFACE_ES, SURFACE_DOT, fmtDate, tourChip } from '../lib/format';

interface Props { tournaments: TournamentCard[] }
const { tournaments } = Astro.props;
---

<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
  {tournaments.map((t) => (
    <a href={`/tournament/${t.id}`} class="card-hover block p-4 no-underline">
      <div class="flex items-center justify-between gap-2 text-2xs text-ink-muted">
        <span class={`chip ${tourChip(t.tour)}`}>{t.tour}</span>
        <span>{t.season}</span>
      </div>
      <div class="mt-2 font-display font-semibold text-ink">{t.name}</div>
      <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-2xs text-ink-faint">
        {t.surface && (
          <span class="flex items-center gap-1">
            <span class={`h-1.5 w-1.5 rounded-full ${SURFACE_DOT[t.surface] ?? 'bg-ink-faint'}`} />
            {SURFACE_ES[t.surface] ?? t.surface}
          </span>
        )}
        {t.series && <span>{t.series}</span>}
      </div>
      <div class="mt-3 flex flex-wrap gap-1.5 text-2xs">
        {t.live > 0 && <span class="chip animate-pulse-live bg-live/15 text-live">{t.live} en vivo</span>}
        {t.scheduled > 0 && <span class="chip bg-court/15 text-court-ink">{t.scheduled} por jugar</span>}
        {t.played > 0 && <span class="chip bg-surface-2 text-ink-muted">{t.played} jugados</span>}
      </div>
      {t.lastDate && (
        <div class="mt-2 text-2xs text-ink-faint">{fmtDate(t.firstDate ?? t.lastDate)} – {fmtDate(t.lastDate)}</div>
      )}
    </a>
  ))}
</div>
