---
import Base from '../../layouts/Base.astro';
import MatchList from '../../components/MatchList.tsx';
import { getTournamentDetail } from '../../lib/queries';
import { surfaceLabel, SURFACE_ES, tourChip } from '../../lib/format';

export const prerender = false;

const id = Number(Astro.params.id);
const detail = Number.isFinite(id) ? await getTournamentDetail(id) : null;

if (!detail) {
  return new Response(null, { status: 404, statusText: 'Torneo no encontrado' });
}
const { card, rounds } = detail;
---

<Base title={`${card.name} · Tennis Trader Intelligence`}>
  <a href="/" class="mb-4 inline-flex items-center gap-1 text-sm text-court-ink no-underline hover:text-court">← Volver</a>

  <div class="card mb-6 p-5">
    <div class="flex flex-wrap items-center gap-2 text-2xs text-ink-muted">
      <span class={`chip ${tourChip(card.tour)}`}>{card.tour}</span>
      <span>{card.season}</span>
      {card.surface && <span>· {surfaceLabel(card.surface)}</span>}
      {card.series && <span>· {card.series}</span>}
    </div>
    <h1 class="mt-2 font-display text-2xl font-semibold tracking-tight">{card.name}</h1>
    <div class="mt-3 flex flex-wrap gap-2 text-2xs">
      {card.live > 0 && <span class="chip animate-pulse-live bg-live/15 text-live">{card.live} en vivo</span>}
      {card.scheduled > 0 && <span class="chip bg-court/15 text-court-ink">{card.scheduled} por jugar</span>}
      {card.played > 0 && <span class="chip bg-surface-2 text-ink-muted">{card.played} jugados</span>}
    </div>
  </div>

  <div class="space-y-8">
    {rounds.map((r) => (
      <section>
        <div class="mb-3 flex items-center gap-3">
          <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-ink-muted">{r.round}</h2>
          <span class="h-px flex-1 bg-line"></span>
          <span class="text-2xs tabular-nums text-ink-faint">{r.matches.length}</span>
        </div>
        <MatchList client:visible matches={r.matches} />
      </section>
    ))}
  </div>
</Base>
