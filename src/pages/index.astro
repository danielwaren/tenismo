---
import Base from '../layouts/Base.astro';
import Buscador from '../components/Buscador.tsx';
import MatchList from '../components/MatchList.tsx';
import { getStats, getUpcomingMatches, getPaperSummary } from '../lib/queries';

export const prerender = false;

const [stats, upcoming, paper] = await Promise.all([
  getStats(),
  getUpcomingMatches(20),
  getPaperSummary(),
]);

const n = (x: number) => x.toLocaleString('es-CL');
const cards = [
  { label: 'Partidos', value: n(stats.matches), hint: `${n(stats.completed)} jugados` },
  { label: 'Con cuota real', value: n(stats.withOdds), hint: 'cuotas de cierre' },
  { label: 'Jugadores', value: n(stats.players), hint: `${n(stats.tournaments)} torneos` },
  { label: 'Pronósticos', value: n(stats.predictions), hint: 'backtest sin look-ahead' },
];
---

<Base subtitle="Elo por superficie para ATP y WTA, contrastado contra cuotas reales." active="home">
  <section class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
    {cards.map((c) => (
      <div class="rounded-lg border border-slate-800 bg-slate-900/40 p-4">
        <div class="text-xs uppercase tracking-wide text-slate-400">{c.label}</div>
        <div class="mt-1 font-mono text-2xl tabular-nums text-court-400">{c.value}</div>
        <div class="mt-0.5 text-xs text-slate-500">{c.hint}</div>
      </div>
    ))}
  </section>

  <section class="mb-8">
    <h2 class="mb-3 text-lg font-semibold">Próximos partidos</h2>
    {upcoming.length > 0 ? (
      <MatchList client:load matches={upcoming} />
    ) : (
      <div class="rounded-lg border border-slate-800 bg-slate-900/40 p-4 text-sm text-slate-400">
        <p>No hay partidos programados ahora mismo.</p>
        <p class="mt-2 text-xs leading-relaxed text-slate-500">
          El calendario futuro viene de The Odds API, que solo cubre Grand Slams, Masters 1000 y
          algunos 500 — y hay semanas sin ningún torneo cubierto. En cuanto arranque uno, el
          proceso diario lo recogerá automáticamente. Mientras tanto, puedes explorar los
          {' '}{n(stats.completed)} partidos ya jugados con el buscador.
        </p>
      </div>
    )}
  </section>

  {paper && (
    <section class="mb-8 rounded-lg border border-amber-900/50 bg-amber-950/20 p-4 text-sm">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-amber-200">Paper Trading — modo auditoría</h2>
        <a href="/paper-trading" class="text-xs text-court-400 no-underline hover:underline">ver detalle →</a>
      </div>
      <p class="mt-1 text-xs leading-relaxed text-amber-100/70">
        Apuestas simuladas con dinero ficticio y cuotas reales. El backtest mostró que la ventaja
        del modelo es anti-predictiva, así que esto NO busca ganar: mide CLV. Apuestas registradas:
        {' '}{paper.total}.
      </p>
    </section>
  )}

  <section>
    <h2 class="mb-3 text-lg font-semibold">Buscar partidos</h2>
    <Buscador client:load />
  </section>
</Base>
