---
import '../styles/global.css';
import Logo from '../components/Logo.astro';

interface Props {
  title?: string;
  subtitle?: string;
  active?: string;
}
const { title = 'Tennis Trader Intelligence', subtitle, active } = Astro.props;

const nav = [
  { href: '/', label: 'Panel', key: 'home' },
  { href: '/ranking', label: 'Ranking', key: 'ranking' },
  { href: '/paper-trading', label: 'Paper Trading', key: 'paper' },
  { href: '/calibracion', label: 'Calibración', key: 'calibracion' },
  { href: '/guia', label: 'Guía', key: 'guia' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Análisis y pronóstico de tenis ATP y WTA contrastado con el mercado." />
  </head>
  <body class="min-h-dvh">
    <header class="sticky top-0 z-40 border-b border-line bg-bg/85 backdrop-blur">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="flex h-16 items-center justify-between gap-4">
          <a href="/" class="flex items-center gap-2.5 no-underline">
            <Logo />
            <span class="font-display text-base font-semibold tracking-tight text-ink sm:text-lg">
              Tennis Trader<span class="text-court"> Intelligence</span>
            </span>
          </a>
          <nav class="hidden items-center gap-0.5 sm:flex" aria-label="Principal">
            {nav.map((n) => (
              <a
                href={n.href}
                aria-current={active === n.key ? 'page' : undefined}
                class:list={[
                  'rounded-lg px-3 py-2 text-sm font-medium no-underline',
                  active === n.key ? 'bg-surface-2 text-court-ink' : 'text-ink-muted hover:text-ink',
                ]}
              >{n.label}</a>
            ))}
          </nav>
        </div>
        <!-- Nav móvil: scroll horizontal contenido, sin desbordar el body. -->
        <nav class="-mx-4 flex gap-0.5 overflow-x-auto px-4 pb-2 sm:hidden" aria-label="Principal móvil">
          {nav.map((n) => (
            <a
              href={n.href}
              aria-current={active === n.key ? 'page' : undefined}
              class:list={[
                'shrink-0 rounded-lg px-3 py-1.5 text-sm font-medium no-underline',
                active === n.key ? 'bg-surface-2 text-court-ink' : 'text-ink-muted',
              ]}
            >{n.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
      {subtitle && <p class="mb-6 max-w-2xl text-sm leading-relaxed text-ink-muted">{subtitle}</p>}
      <slot />
    </main>

    <footer class="mx-auto mt-8 max-w-6xl border-t border-line px-4 py-6 text-xs leading-relaxed text-ink-faint sm:px-6">
      Herramienta de análisis y auditoría. No ejecuta apuestas, no se conecta a ninguna casa
      y no gestiona dinero real. El Paper Trading usa dinero simulado y cuotas reales.
    </footer>
  </body>
</html>
