---
import '../styles/global.css';

interface Props {
  title?: string;
  subtitle?: string;
}
const { title = 'Tennis Trader Intelligence', subtitle } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-slate-800 bg-slate-900/60">
      <div class="mx-auto max-w-5xl px-5 py-5">
        <div class="flex items-baseline gap-3">
          <span class="text-2xl">🎾</span>
          <h1 class="text-xl font-semibold tracking-tight">Tennis Trader Intelligence</h1>
          <span class="rounded bg-court-900 px-2 py-0.5 text-xs font-medium text-court-100">Fase 1</span>
        </div>
        {subtitle && <p class="mt-1 text-sm text-slate-400">{subtitle}</p>}
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-8">
      <slot />
    </main>

    <footer class="mx-auto max-w-5xl px-5 pb-10 pt-4 text-xs leading-relaxed text-slate-500">
      Herramienta de análisis y auditoría. No ejecuta apuestas, no se conecta a ninguna casa
      y no gestiona dinero real. El Paper Trading usa dinero simulado y cuotas reales.
    </footer>
  </body>
</html>
