# ── Base de datos (Turso / libSQL) ─────────────────────────────────────────────
# En desarrollo puedes dejar la URL de fichero local: no hace falta cuenta Turso
# para trabajar. El mismo cliente @libsql/client sirve para los dos.
#
#   local  → file:./data/tennis.db
#   Turso  → libsql://<nombre-bd>-<org>.turso.io
TURSO_DATABASE_URL=file:./data/tennis.db

# Solo para Turso. NO se necesita con file:. Este token da acceso TOTAL a la base
# (Turso no tiene RLS): nunca debe llegar al navegador ni commitearse.
TURSO_AUTH_TOKEN=

# ── Cuotas de partidos futuros (Fase 2) ───────────────────────────────────────
# The Odds API, scope tenis. Sin esta key la ingesta de cuotas es un no-op
# explícito: NO se inventan cuotas a partir del modelo (regla no negociable).
ODDS_API_KEY=
